# Auth
JWT_SECRET=your-jwt-secret-here

# API
PORT=3000
VERIFICATION_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/verification-queue.fifo

# Worker (WORKER_TYPE is set per-process by npm run dev:services)

# AI Validator
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_PROVIDER=anthropic
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=1536
CLAUDE_TIMEOUT_MS=30000
CLAUDE_MAX_RETRIES=3
VALIDATOR_CONCURRENCY=3
VALIDATOR_BATCH_DELAY_MS=1000

# Scraper — Provider Selection
# Options: mock | opencorporates-api | opencorporates
SCRAPER_PROVIDER=opencorporates-api
# Options: default | empty | dissolved | multi (only used with mock provider)
MOCK_SCRAPER_SCENARIO=default

# Scraper — OpenCorporates REST API
OC_API_BASE_URL=https://api.opencorporates.com
OC_API_TOKEN=your-opencorporates-api-token

# Scraper — OpenCorporates Puppeteer (stealth)
OC_EMAIL=your-opencorporates-email
OC_PASSWORD=your-opencorporates-password
OC_BASE_URL=https://opencorporates.com
OC_COOKIES_PATH=services/worker/.oc-cookies.json
BROWSER_HEADLESS=true
SCRAPER_PAGE_TIMEOUT_MS=15000
SCRAPER_MAX_RETRIES=3

# AWS / LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
SQS_ENDPOINT=http://localhost:4566
DYNAMODB_ENDPOINT=http://localhost:4566

# SQS Queue URLs
SQS_VERIFICATION_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/verification-queue.fifo
SQS_VALIDATION_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/validation-queue.fifo
SQS_STORAGE_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/storage-queue.fifo

# DynamoDB Tables
DYNAMODB_TABLE_JOBS=jobs
DYNAMODB_TABLE_VERIFICATIONS=verifications

# Redis
REDIS_URL=redis://localhost:6379

# Ollama (future — local fine-tuned model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct